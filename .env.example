# Supabase → Project Settings → API
# Paste your values below (no quotes needed)

# Project URL (looks like https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (also called "anon" / "public" key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (also called "service_role" key) — server only, never expose to the browser
SUPABASE_SECRET_KEY=

# Your live site URL (used for origin checks), e.g. https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=

# Optional extra salt for hashing IPs in rate limiting
RATE_LIMIT_SALT=
